# 配置模板：复制为 .env.local 并填写真实值（.env.local 不入 git）
# 共享项 + BOTS 列表（每个机器人一项，可配置多个实现单进程多机器人）
# 一 chat_id 一 work_dir：每个机器人绑定一个群 + 一个工作目录；chat_id 唯一
# work_dir 可省略，省略则用家目录 ~
# 数据库为 MySQL
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
POLL_INTERVAL=5
TASK_TIMEOUT=600
# 长任务心跳：处理期间每隔多少秒回一条「仍在处理中」，0=关闭（间隔会逐步加倍，上限 10 分钟）
HEARTBEAT_INTERVAL=60
# 全局并发上限：所有机器人同时运行的 claude 进程数上限（不同 chat_id 并行、同一 chat_id 串行）
# 按内存/CPU 估：每个 claude 约几百 MB~1G，16G/4 核建议 3~4
MAX_CONCURRENT=3
# /model 可选模型清单（可选，留空用默认 opus/sonnet/haiku）
MODELS=["fable","opus","sonnet","haiku"]
# BOTS 支持多行 JSON（会自动拼接到括号闭合），方便编辑；每个机器人一项
BOTS=[
  {"name":"bot1","app_id":"","app_secret":"","chat_id":"","work_dir":"/abs/path"}
]
